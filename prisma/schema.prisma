generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                    BigInt                  @id(map: "pk_users") @default(autoincrement())
  public_id             String                  @unique(map: "uk_users_public_id") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                 String?                 @unique(map: "uk_users_email") @db.VarChar(255)
  password_hash         String?
  google_id             String?                 @unique(map: "uk_users_google_id") @db.VarChar(512)
  google_email          String?                 @db.VarChar(255)
  email_verified        Boolean                 @default(false)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  name                  String?                 @db.VarChar(64)
  cart_items            cart_items[]
  orders                orders[]
  user_prompt_favorites user_prompt_favorites[]

  @@index([created_at], map: "idx_users_created_at")
}

model files {
  id         BigInt    @id @default(autoincrement())
  public_id  String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ref_table  String
  ref_id     BigInt
  file_type  String
  position   Int       @default(0)
  bucket     String?   @db.VarChar(128)
  url        String
  metadata   Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([file_type], map: "idx_files_file_type")
  @@index([ref_table, ref_id], map: "idx_files_ref_table_ref_id")
}

model kv_store {
  id         BigInt    @id @default(autoincrement())
  json_key   String    @unique @db.VarChar(128)
  json_value Json
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model prompts {
  id                    BigInt                  @id @default(autoincrement())
  public_id             String                  @unique(map: "uk_prompts_public_id") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  description           String?
  price                 Int
  enabled               Boolean                 @default(false)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  bonus_credit          Int                     @default(0)
  user_prompt_favorites user_prompt_favorites[]

  @@index([description], map: "idx_prompts_description")
  @@index([name], map: "idx_prompts_name")
}

model user_prompt_favorites {
  user_id    BigInt
  prompt_id  BigInt
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  prompts    prompts  @relation(fields: [prompt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, prompt_id])
  @@index([user_id, updated_at(sort: Desc)], map: "idx_user_prompt_favorites_updated_at")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  item_type  String   @db.VarChar(50)
  item_id    BigInt
  quantity   Int      @default(1)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, item_type, item_id], map: "uk_cart_user_id_item_type_item_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id         BigInt   @id @default(autoincrement())
  order_id   BigInt
  item_type  String   @db.VarChar(50)
  item_id    BigInt
  quantity   Int      @default(1)
  unit_price Int
  amount     Int
  created_at DateTime @default(now()) @db.Timestamptz(6)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id], map: "idx_order_items_order_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id          BigInt        @id @default(autoincrement())
  user_id     BigInt
  status      String        @default("PENDING") @db.VarChar(50)
  amount      Int
  currency    String        @default("TWD") @db.VarChar(10)
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  updated_at  DateTime      @default(now()) @db.Timestamptz(6)
  order_items order_items[]
  users       users         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payments    payments[]

  @@index([status], map: "idx_orders_status")
  @@index([user_id], map: "idx_orders_user_id")
}

model payments {
  id                  BigInt    @id @default(autoincrement())
  order_id            BigInt
  provider            String    @db.VarChar(50)
  status              String    @default("PENDING") @db.VarChar(50)
  provider_payment_id String    @db.VarChar(512)
  provider_session_id String?   @db.VarChar(512)
  checkout_url        String?
  raw_payload         Json?
  expires_at          DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  orders              orders    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_payment_id], map: "uk_payments_provider_payment_id")
  @@index([order_id], map: "idx_payments_order_id")
  @@index([provider, status], map: "idx_payments_provider_status")
}
