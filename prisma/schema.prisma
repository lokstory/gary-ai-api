generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                    BigInt                  @id(map: "pk_users") @default(autoincrement())
  uuid                  String                  @unique(map: "uk_users_uuid") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                 String?                 @unique(map: "uk_users_email") @db.VarChar(255)
  name                  String?                 @db.VarChar(64)
  password_hash         String?
  google_id             String?                 @unique(map: "uk_users_google_id") @db.VarChar(512)
  google_email          String?                 @db.VarChar(255)
  email_verified        Boolean                 @default(false)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  locale                String?                 @db.VarChar(16)
  cart_items            cart_items[]
  orders                orders[]
  user_prompt_favorites user_prompt_favorites[]
  user_prompts          user_prompts[]

  @@index([created_at], map: "idx_users_created_at")
}

model files {
  id          BigInt    @id @default(autoincrement())
  uuid        String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ref_table   String    @db.VarChar(128)
  ref_id      BigInt
  category    String    @db.VarChar(64)
  file_type   String    @db.VarChar(64)
  parent_id   BigInt?
  position    Int       @default(0)
  bucket      String    @db.VarChar(64)
  url         String
  metadata    Json?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)
  files       files?    @relation("filesTofiles", fields: [parent_id], references: [id], onUpdate: NoAction, map: "fk_files_parent_id")
  other_files files[]   @relation("filesTofiles")

  @@index([file_type], map: "idx_files_file_type")
  @@index([ref_table, ref_id], map: "idx_files_ref_table_ref_id")
  @@index([category], map: "idx_files_category")
  @@index([parent_id], map: "idx_files_parent_id")
  @@index([ref_table, ref_id, category, position], map: "idx_files_ref_table_ref_id_category_position")
}

model kv_store {
  id         BigInt    @id @default(autoincrement())
  json_key   String    @unique @db.VarChar(128)
  json_value Json
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model prompts {
  id                    BigInt                  @id @default(autoincrement())
  uuid                  String                  @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  price                 Int
  bonus_credit          Int                     @default(0)
  enabled               Boolean                 @default(false)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  media_type            String?                 @db.VarChar(16)
  category_id           Int?
  featured_rank         Int                     @default(-1)
  prompt_labels         prompt_labels[]
  prompt_translations   prompt_translations[]
  categories            categories?             @relation(fields: [category_id], references: [id], map: "fk_prompts_category_id")
  user_prompt_favorites user_prompt_favorites[]
  user_prompts          user_prompts[]

  @@index([category_id], map: "idx_prompts_category_id")
  @@index([media_type], map: "idx_prompts_media_type")
  @@index([enabled, featured_rank, created_at(sort: Desc)], map: "idx_prompts_enabled_featured_rank_created_at")
  @@index([featured_rank], map: "idx_prompts_featured_rank")
}

model user_prompt_favorites {
  user_id    BigInt
  prompt_id  BigInt
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  prompts    prompts  @relation(fields: [prompt_id], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, prompt_id])
  @@index([user_id, updated_at(sort: Desc)], map: "idx_user_prompt_favorites_updated_at")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  item_type  String   @db.VarChar(50)
  item_id    BigInt
  quantity   Int      @default(1)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, item_type, item_id], map: "uk_cart_user_id_item_type_item_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id         BigInt   @id @default(autoincrement())
  order_id   BigInt
  item_type  String   @db.VarChar(50)
  item_id    BigInt
  quantity   Int      @default(1)
  unit_price Int
  amount     Int
  created_at DateTime @default(now()) @db.Timestamptz(6)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id], map: "idx_order_items_order_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model orders {
  id           BigInt         @id @default(autoincrement())
  uuid         String         @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      BigInt
  status       String         @default("PENDING") @db.VarChar(50)
  amount       Int
  currency     String         @default("TWD") @db.VarChar(10)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  fingerprint  String?        @db.VarChar(255)
  order_items  order_items[]
  users        users          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payments     payments[]
  user_prompts user_prompts[]

  @@index([status], map: "idx_orders_status")
  @@index([user_id], map: "idx_orders_user_id")
  @@index([user_id, status, fingerprint], map: "idx_orders_user_id_status_fingerprint")
}

model payments {
  id                  BigInt    @id @default(autoincrement())
  order_id            BigInt
  provider            String    @db.VarChar(50)
  status              String    @default("PENDING") @db.VarChar(50)
  provider_payment_id String    @db.VarChar(512)
  provider_session_id String?   @db.VarChar(512)
  checkout_url        String?
  raw_payload         Json?
  expires_at          DateTime? @db.Timestamptz(6)
  created_at          DateTime  @default(now()) @db.Timestamptz(6)
  updated_at          DateTime  @default(now()) @db.Timestamptz(6)
  orders              orders    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_payment_id], map: "uk_payments_provider_payment_id")
  @@index([order_id], map: "idx_payments_order_id")
  @@index([provider, status], map: "idx_payments_provider_status")
}

model user_prompts {
  user_id    BigInt
  prompt_id  BigInt
  order_id   BigInt
  created_at DateTime @default(now()) @db.Timestamptz(6)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  prompts    prompts  @relation(fields: [prompt_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, prompt_id])
}

model admins {
  id            BigInt    @id(map: "pk_admins") @default(autoincrement())
  username      String    @unique(map: "uk_admins_username") @db.VarChar(255)
  password_hash String
  name          String?   @db.VarChar(128)
  role          String?   @db.VarChar(50)
  enabled       Boolean
  last_login_at DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_admins_created_at")
  @@index([enabled], map: "idx_admins_enabled")
}

model labels {
  id                 Int                  @id(map: "pk_labels") @default(autoincrement())
  code               String               @unique(map: "uk_labels_code") @db.VarChar(100)
  enabled            Boolean              @default(true)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @db.Timestamptz(6)
  label_translations label_translations[]
  prompt_labels      prompt_labels[]

  @@index([created_at], map: "idx_labels_created_at")
  @@index([enabled], map: "idx_labels_enabled")
}

model categories {
  id                    Int                     @id(map: "pk_categories") @default(autoincrement())
  code                  String                  @unique(map: "uk_categories_code") @db.VarChar(100)
  enabled               Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @db.Timestamptz(6)
  category_translations category_translations[]
  prompts               prompts[]

  @@index([created_at], map: "idx_categories_created_at")
  @@index([enabled], map: "idx_categories_enabled")
}

model prompt_labels {
  prompt_id  BigInt
  label_id   Int
  created_at DateTime @default(now()) @db.Timestamptz(6)
  labels     labels   @relation(fields: [label_id], references: [id], onDelete: Cascade, map: "fk_prompt_labels_label_id")
  prompts    prompts  @relation(fields: [prompt_id], references: [id], onDelete: Cascade, map: "fk_prompt_labels_prompt_id")

  @@id([prompt_id, label_id], map: "pk_prompt_labels")
  @@index([label_id], map: "idx_prompt_labels_label_id")
}

model category_translations {
  id          BigInt     @id @default(autoincrement())
  category_id Int
  locale      String     @db.VarChar(16)
  name        String     @db.VarChar(255)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade, map: "fk_category_translations_category_id")

  @@unique([category_id, locale], map: "uk_category_translations_category_id_locale")
  @@index([category_id], map: "idx_category_translations_category_id")
  @@index([locale], map: "idx_category_translations_locale")
}

model label_translations {
  id         BigInt   @id @default(autoincrement())
  label_id   Int
  locale     String   @db.VarChar(16)
  name       String   @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  labels     labels   @relation(fields: [label_id], references: [id], onDelete: Cascade, map: "fk_label_translations_label_id")

  @@unique([label_id, locale], map: "uk_label_translations_label_id_locale")
  @@index([label_id], map: "idx_label_translations_label_id")
  @@index([locale], map: "idx_label_translations_locale")
}

model prompt_translations {
  id          BigInt   @id @default(autoincrement())
  prompt_id   BigInt
  locale      String   @db.VarChar(16)
  name        String
  description String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  prompts     prompts  @relation(fields: [prompt_id], references: [id], onDelete: Cascade, map: "fk_prompt_translations_prompt_id")

  @@unique([prompt_id, locale], map: "uk_prompt_translations_prompt_id_locale")
  @@index([locale], map: "idx_prompt_translations_locale")
  @@index([prompt_id], map: "idx_prompt_translations_prompt_id")
}
