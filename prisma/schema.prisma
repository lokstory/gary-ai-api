generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id             BigInt   @id(map: "pk_users") @default(autoincrement())
  public_id      String   @unique(map: "uk_users_public_id") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String?  @unique(map: "uk_users_email") @db.VarChar(255)
  password_hash  String?
  google_id      String?  @unique(map: "uk_users_google_id") @db.VarChar(512)
  google_email   String?  @db.VarChar(255)
  email_verified Boolean  @default(false)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at], map: "idx_users_created_at")
}

model files {
  id         BigInt    @id @default(autoincrement())
  ref_table  String
  ref_id     BigInt
  file_type  String
  position   Int       @default(0)
  url        String
  metadata   Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([file_type], map: "idx_files_file_type")
  @@index([ref_table, ref_id], map: "idx_files_ref_table_ref_id")
}

model kv_store {
  id         BigInt    @id @default(autoincrement())
  json_key   String    @unique @db.VarChar(128)
  json_value Json
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
}

model prompts {
  id          BigInt    @id @default(autoincrement())
  public_id   String    @unique(map: "uk_prompts_public_id") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  price       Int
  prompt      String?
  enabled     Boolean   @default(false)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([description], map: "idx_prompts_description")
  @@index([name], map: "idx_prompts_name")
}
